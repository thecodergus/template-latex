{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "latex-author",
  "instructions": [
    "AGENTS.md",
    "README.md",
    ".opencode/agents/latex-author.md"
  ],
  "agent": {
    "latex-author": {
      "description": "Especialista em escrita e compilação de artigos LaTeX com template SBC/SBGames e engine Tectonic",
      "tools": {
        "write": true,
        "edit": true,
        "bash": true,
        "search": true,
        "read": true
      }
    }
  },
  "lsp": {
    "texlab": {
      "command": ["texlab"],
      "extensions": [".tex", ".sty", ".cls", ".bib"],
      "env": {
        "RUST_LOG": "info"
      }
    },
    "ltex-ls": {
      "command": ["ltex-ls"],
      "extensions": [".tex", ".md"],
      "env": {
        "JAVA_OPTS": "-Xmx512m"
      },
      "initialization": {
        "ltex": {
          "language": "pt-BR",
          "additionalRules": {
            "motherTongue": "pt-BR",
            "languageModel": "ngram"
          },
          "disabledRules": {
            "pt-BR": ["WHITESPACE_RULE"]
          }
        }
      }
    },
    "taplo": {
      "command": ["taplo", "lsp", "stdio"],
      "extensions": [".toml"]
    }
  }
}
